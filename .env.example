# PolyWeather — Environment Configuration
# Copy this file and fill in your API keys.
# NEVER commit this file to version control.

# === Apify (Weather Data Scraping) ===
# Get your token at: https://console.apify.com/settings/integrations
# Leave blank to use Open-Meteo free fallback (no key needed)
APIFY_API_TOKEN=

# === OpenRouter (LLM Inference) ===
# Get your key at: https://openrouter.ai/settings/keys
# Required for the Hermes orchestrator agent
OPENROUTER_API_KEY=

# === Telegram Bot (Trade Alerts) ===
# Create a bot via @BotFather on Telegram
# Leave blank to disable Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=6

# === Trading Parameters ===
# Initial paper trading balance in USD
INITIAL_BALANCE=10000

# === Agent Scheduling ===
# Agent cycle interval in minutes
AGENT_CYCLE_MINUTES=30
